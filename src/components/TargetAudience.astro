---
const audiences = [
  {
    title: 'Estudios contables',
    description:
      'Equipos que procesan constancias AFIP en serie y necesitan bajar el tiempo por CUIT sin sumar personal.',
  },
  {
    title: 'Departamentos administrativos',
    description:
      'Áreas de administración y finanzas con volumen documental alto entre sucursales o unidades de negocio.',
  },
  {
    title: 'Empresas con lotes recurrentes',
    description:
      'Organizaciones que cada mes repiten el mismo flujo de consultas, validaciones y archivo de constancias.',
  },
  {
    title: 'Sectores con auditoría exigente',
    description:
      'Industrias donde cada documento debe quedar trazado, fechado y disponible para revisión.',
  },
];
---

<section id="clientes" class="section-pad border-t border-border">
  <div class="container-nexo">
    <div class="reveal mx-auto max-w-2xl text-center" style="--index: 0">
      <p class="eyebrow">Para quién</p>
      <h2 class="heading-display mt-3 text-3xl font-semibold sm:text-4xl">
        Equipos contables y administrativos que operan en volumen
      </h2>
      <p class="mt-4 text-lg text-muted">
        Trabajamos con quienes necesitan resultados medibles en el piso operativo, no solo
        un proyecto de software en el papel.
      </p>
    </div>

    <div class="mt-14 grid gap-4 sm:grid-cols-2">
      {
        audiences.map((item, i) => (
          <article class="card card-hover reveal p-7" style={`--index: ${i + 1}`}>
            <h3 class="text-xl font-medium text-ink">{item.title}</h3>
            <p class="mt-3 text-sm leading-relaxed text-muted">{item.description}</p>
          </article>
        ))
      }
    </div>
  </div>
</section>
