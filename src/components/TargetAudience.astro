---
const audiences = [
  {
    title: 'PyMEs en crecimiento',
    description:
      'Organizaciones que escalan y necesitan dejar atrás planillas, mails y carpetas compartidas en administración.',
  },
  {
    title: 'Empresas medianas',
    description:
      'Equipos con procesos repartidos entre áreas, sucursales o sistemas que ya no se hablan entre sí.',
  },
  {
    title: 'Grandes empresas',
    description:
      'Unidades administrativas que buscan modernizar sin reemplazar de golpe todo el ecosistema existente.',
  },
  {
    title: 'Sectores regulados',
    description:
      'Industrias con exigencias de trazabilidad, auditoría y cumplimiento en cada paso del proceso.',
  },
];
---

<section id="clientes" class="section-pad border-t border-border">
  <div class="container-nexo">
    <div class="reveal mx-auto max-w-2xl text-center" style="--index: 0">
      <p class="eyebrow">Para quién</p>
      <h2 class="heading-display mt-3 text-3xl font-semibold sm:text-4xl">
        Empresas con procesos administrativos manuales o fragmentados
      </h2>
      <p class="mt-4 text-lg text-muted">
        Trabajamos con dirección, operaciones, administración y finanzas cuando el desafío
        es ganar velocidad y control en la gestión del día a día.
      </p>
    </div>

    <div class="mt-14 grid gap-4 sm:grid-cols-2">
      {
        audiences.map((item, i) => (
          <article class="card card-hover reveal p-7" style={`--index: ${i + 1}`}>
            <h3 class="text-xl font-medium text-ink">{item.title}</h3>
            <p class="mt-3 text-sm leading-relaxed text-muted">{item.description}</p>
          </article>
        ))
      }
    </div>
  </div>
</section>
