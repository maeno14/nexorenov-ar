---
const steps = [
  {
    step: '01',
    title: 'Diagnóstico',
    description:
      'Entrevistas, revisión de flujos y priorización de quick wins junto a los responsables de cada área.',
  },
  {
    step: '02',
    title: 'Diseño',
    description:
      'Arquitectura de procesos, integraciones y roadmap con entregables claros por fase.',
  },
  {
    step: '03',
    title: 'Implementación',
    description:
      'Desarrollo, migración de datos y despliegue con pruebas junto a usuarios reales del negocio.',
  },
  {
    step: '04',
    title: 'Soporte',
    description:
      'Seguimiento de adopción, ajustes y escalado con métricas de uso del equipo.',
  },
];
---

<section id="proceso" class="section-pad border-t border-border bg-canvas-alt">
  <div class="container-nexo">
    <div class="reveal max-w-2xl" style="--index: 0">
      <p class="eyebrow">Cómo trabajamos</p>
      <h2 class="heading-display mt-3 text-3xl font-semibold sm:text-4xl">
        Un método claro, de punta a punta
      </h2>
    </div>

    <ol class="mt-14 grid gap-8 md:grid-cols-2 lg:grid-cols-4">
      {
        steps.map((item, i) => (
          <li class="reveal border-t border-border pt-6" style={`--index: ${i + 1}`}>
            <span class="font-mono text-sm text-muted">{item.step}</span>
            <h3 class="mt-4 text-xl font-medium text-ink">{item.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-muted">{item.description}</p>
          </li>
        ))
      }
    </ol>
  </div>
</section>
