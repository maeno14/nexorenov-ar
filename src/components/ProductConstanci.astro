---
import { site, productExternalUrl } from '../config/site';

const benefits = [
  'Carga masiva por Excel: miles de CUITs en un solo archivo, sin trabajo manual',
  'Descarga automática desde AFIP, con resolución de captcha en segundo plano',
  'PDFs oficiales listos en un ZIP — 100% web y sin clave fiscal',
  'Historial de lotes, créditos y reportes para auditar cada operación',
];

const steps = [
  { step: '1', title: 'Subí tu Excel', detail: 'Lista de CUITs con la plantilla del servicio.' },
  { step: '2', title: 'Procesamos el lote', detail: 'Cada constancia se consulta en AFIP de forma automática.' },
  { step: '3', title: 'Descargá el ZIP', detail: 'PDFs oficiales y detalle de éxitos, pendientes y errores.' },
];
---

<section id="constanci" class="section-pad bg-nexo-ink text-white">
  <div class="container-nexo">
    <div class="grid items-center gap-12 lg:grid-cols-2 lg:gap-16">
      <div>
        <p class="text-sm font-semibold uppercase tracking-wider text-teal-300">
          Producto estrella · AFIP
        </p>
        <h2 class="mt-3 font-display text-3xl font-bold tracking-tight sm:text-4xl">
          {site.product.name}
        </h2>
        <p class="mt-2 text-base font-medium text-teal-200">
          Automatización de constancias AFIP
        </p>
        <p class="mt-4 text-lg leading-relaxed text-slate-300">
          {site.product.tagline} Lo desarrollamos desde {site.name} para estudios contables
          y equipos que hoy cargan CUIT por CUIT en AFIP.
        </p>
        <ul class="mt-8 space-y-3">
          {
            benefits.map((benefit) => (
              <li class="flex items-start gap-3 text-sm leading-relaxed text-slate-200 sm:text-base">
                <span
                  class="mt-1 flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-teal-500/20 text-teal-300"
                  aria-hidden="true"
                >
                  ✓
                </span>
                {benefit}
              </li>
            ))
          }
        </ul>
        <a
          href={productExternalUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="mt-10 inline-flex items-center gap-2 rounded-full bg-white px-6 py-3 text-sm font-semibold text-nexo-ink transition hover:bg-teal-50"
        >
          Ver planes en {site.product.name}
          <span aria-hidden="true">→</span>
        </a>
      </div>

      <div class="space-y-6">
        <div class="rounded-2xl border border-white/10 bg-white/5 p-8 backdrop-blur-sm">
          <p class="text-xs font-semibold uppercase tracking-wider text-teal-300">Ideal para</p>
          <p class="mt-4 font-display text-2xl font-semibold leading-snug">
            Estudios contables y equipos que procesan constancias en serie, no de a una.
          </p>
          <div class="mt-8 grid grid-cols-2 gap-4">
            <div class="rounded-xl bg-white/10 p-4">
              <p class="text-2xl font-bold text-teal-300">Excel</p>
              <p class="mt-1 text-xs text-slate-300">carga masiva de CUITs</p>
            </div>
            <div class="rounded-xl bg-white/10 p-4">
              <p class="text-2xl font-bold text-teal-300">AFIP</p>
              <p class="mt-1 text-xs text-slate-300">PDF oficial automático</p>
            </div>
            <div class="rounded-xl bg-white/10 p-4">
              <p class="text-2xl font-bold text-teal-300">24/7</p>
              <p class="mt-1 text-xs text-slate-300">procesamiento en segundo plano</p>
            </div>
            <div class="rounded-xl bg-white/10 p-4">
              <p class="text-2xl font-bold text-teal-300">Sin clave</p>
              <p class="mt-1 text-xs text-slate-300">fiscal para operar</p>
            </div>
          </div>
        </div>

        <div class="rounded-2xl border border-white/10 bg-white/5 p-6 backdrop-blur-sm">
          <p class="text-xs font-semibold uppercase tracking-wider text-teal-300">
            De Excel a ZIP
          </p>
          <ol class="mt-4 space-y-4">
            {
              steps.map((item) => (
                <li class="flex gap-4">
                  <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-teal-500/20 text-sm font-bold text-teal-300">
                    {item.step}
                  </span>
                  <div>
                    <p class="font-semibold text-white">{item.title}</p>
                    <p class="mt-0.5 text-sm text-slate-400">{item.detail}</p>
                  </div>
                </li>
              ))
            }
          </ol>
        </div>
      </div>
    </div>
  </div>
</section>
