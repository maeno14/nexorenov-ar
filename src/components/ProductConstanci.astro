---
import { site, productExternalUrl } from '../config/site';
---

<section id="productos" class="section-pad border-t border-border bg-surface">
  <div class="container-nexo">
    <div class="reveal max-w-2xl" style="--index: 0">
      <p class="eyebrow">Productos</p>
      <h2 class="heading-display mt-3 text-3xl font-semibold sm:text-4xl">
        Software que construimos al resolver problemas reales
      </h2>
      <p class="mt-4 text-lg text-muted">
        La consultoría es el núcleo de {site.name}. Cuando un proceso se repite en escala,
        también desarrollamos productos listos para operar — sin mezclar el servicio con la
        herramienta.
      </p>
    </div>

    <article class="card card-hover reveal mt-10 p-8 lg:p-10" style="--index: 1">
      <div class="flex flex-col gap-6 lg:flex-row lg:items-start lg:justify-between">
        <div class="max-w-xl">
          <span class="tag tag-green">Producto</span>
          <h3 class="mt-4 text-2xl font-medium text-ink">{site.product.name}</h3>
          <p class="mt-3 text-base text-muted">{site.product.summary}</p>
          <p class="mt-4 text-sm text-muted">{site.product.tagline}</p>
        </div>
        <a
          href={productExternalUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="btn-secondary shrink-0 self-start"
        >
          Ir a {site.product.name}
        </a>
      </div>
    </article>
  </div>
</section>
