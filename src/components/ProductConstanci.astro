---
import { site, productExternalUrl } from '../config/site';

const benefits = [
  'Carga masiva por Excel: miles de CUITs en un solo archivo',
  'Descarga automática desde AFIP, con resolución de captcha en segundo plano',
  'PDFs oficiales listos en un ZIP — 100% web y sin clave fiscal',
  'Historial de lotes, créditos y reportes para auditar cada operación',
];

const steps = [
  { step: '1', title: 'Subí tu Excel', detail: 'Lista de CUITs con la plantilla del servicio.' },
  { step: '2', title: 'Procesamos el lote', detail: 'Cada constancia se consulta en AFIP de forma automática.' },
  { step: '3', title: 'Descargá el ZIP', detail: 'PDFs oficiales y detalle de éxitos, pendientes y errores.' },
];
---

<section id="constanci" class="section-pad border-t border-border bg-surface">
  <div class="container-nexo">
    <div class="grid items-start gap-12 lg:grid-cols-2 lg:gap-16">
      <div class="reveal" style="--index: 0">
        <span class="tag tag-green">Producto estrella · AFIP</span>
        <h2 class="heading-display mt-4 text-3xl font-semibold sm:text-4xl">
          {site.product.name}
        </h2>
        <p class="mt-3 text-base font-medium text-ink">Automatización de constancias AFIP</p>
        <p class="mt-4 text-lg leading-relaxed text-muted">
          {site.product.tagline} Lo desarrollamos desde {site.name} para estudios contables
          y equipos que hoy cargan CUIT por CUIT en AFIP.
        </p>
        <ul class="mt-8 space-y-3">
          {
            benefits.map((benefit) => (
              <li class="flex items-start gap-3 text-sm leading-relaxed text-muted sm:text-base">
                <span class="mt-0.5 font-mono text-xs text-ink" aria-hidden="true">
                  —
                </span>
                {benefit}
              </li>
            ))
          }
        </ul>
        <a
          href={productExternalUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="btn-primary mt-10"
        >
          Ver planes en {site.product.name}
        </a>
      </div>

      <div class="reveal space-y-6" style="--index: 1">
        <div class="card overflow-hidden">
          <div class="flex items-center gap-2 border-b border-border px-4 py-3">
            <span class="h-2.5 w-2.5 rounded-full bg-border" aria-hidden="true"></span>
            <span class="h-2.5 w-2.5 rounded-full bg-border" aria-hidden="true"></span>
            <span class="h-2.5 w-2.5 rounded-full bg-border" aria-hidden="true"></span>
            <span class="ml-2 font-mono text-xs text-muted">lote_cuits.xlsx</span>
          </div>
          <div class="space-y-4 p-6">
            <div class="flex items-center justify-between text-sm">
              <span class="text-muted">Progreso del lote</span>
              <span class="font-mono text-ink">847 / 1.000</span>
            </div>
            <div class="h-1.5 w-full overflow-hidden rounded-full bg-canvas-alt">
              <div class="h-full w-[84.7%] rounded-full bg-ink"></div>
            </div>
            <div class="grid grid-cols-3 gap-3 text-center">
              <div class="rounded-md border border-border bg-canvas-alt p-3">
                <p class="font-mono text-lg text-ink">812</p>
                <p class="mt-1 text-xs text-muted">Exitosas</p>
              </div>
              <div class="rounded-md border border-border bg-canvas-alt p-3">
                <p class="font-mono text-lg text-ink">153</p>
                <p class="mt-1 text-xs text-muted">Pendientes</p>
              </div>
              <div class="rounded-md border border-border bg-pastel-red-bg p-3">
                <p class="font-mono text-lg text-pastel-red-text">35</p>
                <p class="mt-1 text-xs text-muted">Errores</p>
              </div>
            </div>
            <p class="rounded-md border border-border bg-pastel-green-bg px-3 py-2 text-center text-xs font-medium text-pastel-green-text">
              ZIP listo para descargar al finalizar
            </p>
          </div>
        </div>

        <div class="card p-6">
          <p class="eyebrow">De Excel a ZIP</p>
          <ol class="mt-4 space-y-4">
            {
              steps.map((item) => (
                <li class="flex gap-4">
                  <span class="font-mono text-sm font-medium text-muted">{item.step}</span>
                  <div>
                    <p class="font-medium text-ink">{item.title}</p>
                    <p class="mt-0.5 text-sm text-muted">{item.detail}</p>
                  </div>
                </li>
              ))
            }
          </ol>
        </div>
      </div>
    </div>
  </div>
</section>
