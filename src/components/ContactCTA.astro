---
import { site } from '../config/site';

const accessKey = import.meta.env.PUBLIC_WEB3FORMS_ACCESS_KEY ?? '';
const hasForm = accessKey.length > 0;
---

<section id="contacto" class="section-pad">
  <div class="container-nexo">
    <div class="overflow-hidden rounded-3xl border border-nexo-border bg-white shadow-xl shadow-slate-200/50">
      <div class="grid lg:grid-cols-2">
        <div class="bg-nexo-ink p-8 text-white sm:p-12">
          <p class="text-sm font-semibold uppercase tracking-wider text-teal-300">Contacto</p>
          <h2 class="mt-3 font-display text-3xl font-bold tracking-tight sm:text-4xl">
            Agendemos una consulta
          </h2>
          <p class="mt-4 leading-relaxed text-slate-300">
            Contanos qué procesos administrativos querés mejorar. Te respondemos con una
            propuesta de diagnóstico inicial.
          </p>
          <div class="mt-8 space-y-4">
            <a
              href={`mailto:${site.email}`}
              class="flex items-center gap-3 text-sm text-slate-200 transition hover:text-white"
            >
              <span class="flex h-9 w-9 items-center justify-center rounded-lg bg-white/10">@</span>
              {site.email}
            </a>
            {
              site.whatsapp && (
                <a
                  href={`https://wa.me/${site.whatsapp}`}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="flex items-center gap-3 text-sm text-slate-200 transition hover:text-white"
                >
                  <span class="flex h-9 w-9 items-center justify-center rounded-lg bg-white/10">
                    WA
                  </span>
                  WhatsApp
                </a>
              )
            }
          </div>
        </div>

        <div class="p-8 sm:p-12">
          {
            hasForm ? (
              <form
                action="https://api.web3forms.com/submit"
                method="POST"
                class="space-y-5"
              >
                <input type="hidden" name="access_key" value={accessKey} />
                <input type="hidden" name="subject" value="Consulta desde nexorenov.ar" />
                <input type="checkbox" name="botcheck" class="hidden" style="display:none" />

                <div>
                  <label for="name" class="mb-1.5 block text-sm font-medium text-nexo-ink">
                    Nombre
                  </label>
                  <input
                    id="name"
                    name="name"
                    type="text"
                    required
                    class="w-full rounded-xl border border-nexo-border bg-nexo-surface px-4 py-3 text-sm outline-none transition focus:border-nexo-accent focus:ring-2 focus:ring-teal-500/20"
                  />
                </div>
                <div>
                  <label for="email" class="mb-1.5 block text-sm font-medium text-nexo-ink">
                    Email corporativo
                  </label>
                  <input
                    id="email"
                    name="email"
                    type="email"
                    required
                    class="w-full rounded-xl border border-nexo-border bg-nexo-surface px-4 py-3 text-sm outline-none transition focus:border-nexo-accent focus:ring-2 focus:ring-teal-500/20"
                  />
                </div>
                <div>
                  <label for="company" class="mb-1.5 block text-sm font-medium text-nexo-ink">
                    Empresa
                  </label>
                  <input
                    id="company"
                    name="company"
                    type="text"
                    class="w-full rounded-xl border border-nexo-border bg-nexo-surface px-4 py-3 text-sm outline-none transition focus:border-nexo-accent focus:ring-2 focus:ring-teal-500/20"
                  />
                </div>
                <div>
                  <label for="message" class="mb-1.5 block text-sm font-medium text-nexo-ink">
                    Mensaje
                  </label>
                  <textarea
                    id="message"
                    name="message"
                    rows="4"
                    required
                    class="w-full resize-none rounded-xl border border-nexo-border bg-nexo-surface px-4 py-3 text-sm outline-none transition focus:border-nexo-accent focus:ring-2 focus:ring-teal-500/20"
                    placeholder="¿Qué procesos administrativos querés digitalizar?"
                  />
                </div>
                <button
                  type="submit"
                  class="w-full rounded-full bg-nexo-accent px-6 py-3 text-sm font-semibold text-white transition hover:bg-nexo-accent-light"
                >
                  Enviar consulta
                </button>
              </form>
            ) : (
              <div class="flex h-full flex-col justify-center">
                <p class="text-sm leading-relaxed text-nexo-muted">
                  El formulario se activa al configurar la variable de entorno{' '}
                  <code class="rounded bg-nexo-surface px-1.5 py-0.5 text-xs text-nexo-ink">
                    PUBLIC_WEB3FORMS_ACCESS_KEY
                  </code>{' '}
                  en Cloudflare Pages. Mientras tanto, escribinos a{' '}
                  <a href={`mailto:${site.email}`} class="font-medium text-nexo-accent hover:underline">
                    {site.email}
                  </a>
                  .
                </p>
                <a
                  href={`mailto:${site.email}?subject=Consulta%20Nexo%20Renov`}
                  class="mt-6 inline-flex w-fit items-center justify-center rounded-full bg-nexo-accent px-6 py-3 text-sm font-semibold text-white transition hover:bg-nexo-accent-light"
                >
                  Enviar email
                </a>
              </div>
            )
          }
        </div>
      </div>
    </div>
  </div>
</section>
