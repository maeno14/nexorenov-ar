---
import { site } from '../config/site';

const accessKey = import.meta.env.PUBLIC_WEB3FORMS_ACCESS_KEY ?? '';
const hasForm = accessKey.length > 0;
---

<section id="contacto" class="section-pad border-t border-border bg-surface">
  <div class="container-nexo">
    <div class="card reveal overflow-hidden" style="--index: 0">
      <div class="grid lg:grid-cols-2">
        <div class="border-b border-border p-8 sm:p-12 lg:border-b-0 lg:border-r">
          <p class="eyebrow">Contacto</p>
          <h2 class="heading-display mt-3 text-3xl font-semibold sm:text-4xl">
            Agendemos una consulta
          </h2>
          <p class="mt-4 leading-relaxed text-muted">
            Contanos qué procesos administrativos querés mejorar. Te respondemos con una
            propuesta de diagnóstico inicial.
          </p>
          <a
            href={`mailto:${site.email}`}
            class="mt-8 inline-flex items-center gap-2 text-sm text-muted transition hover:text-ink"
          >
            <span class="font-mono text-xs">@</span>
            {site.email}
          </a>
        </div>

        <div class="p-8 sm:p-12">
          {
            hasForm ? (
              <form action="https://api.web3forms.com/submit" method="POST" class="space-y-5">
                <input type="hidden" name="access_key" value={accessKey} />
                <input type="hidden" name="subject" value="Consulta desde nexoceler.ar" />
                <input type="checkbox" name="botcheck" class="hidden" style="display:none" />

                <div>
                  <label for="name" class="mb-1.5 block text-sm font-medium text-ink">
                    Nombre
                  </label>
                  <input id="name" name="name" type="text" required class="input-field" />
                </div>
                <div>
                  <label for="email" class="mb-1.5 block text-sm font-medium text-ink">
                    Email corporativo
                  </label>
                  <input id="email" name="email" type="email" required class="input-field" />
                </div>
                <div>
                  <label for="company" class="mb-1.5 block text-sm font-medium text-ink">
                    Empresa
                  </label>
                  <input id="company" name="company" type="text" class="input-field" />
                </div>
                <div>
                  <label for="message" class="mb-1.5 block text-sm font-medium text-ink">
                    Mensaje
                  </label>
                  <textarea
                    id="message"
                    name="message"
                    rows="4"
                    required
                    class="input-field resize-none"
                    placeholder="¿Qué procesos administrativos querés digitalizar?"
                  />
                </div>
                <button type="submit" class="btn-primary w-full"> Enviar consulta </button>
              </form>
            ) : (
              <div class="flex h-full flex-col justify-center">
                <p class="text-sm leading-relaxed text-muted">
                  El formulario se activa al configurar{' '}
                  <code class="rounded bg-canvas-alt px-1.5 py-0.5 font-mono text-xs text-ink">
                    PUBLIC_WEB3FORMS_ACCESS_KEY
                  </code>{' '}
                  en Cloudflare Pages. Mientras tanto, escribinos a{' '}
                  <a href={`mailto:${site.email}`} class="font-medium text-ink hover:underline">
                    {site.email}
                  </a>
                  .
                </p>
                <a
                  href={`mailto:${site.email}?subject=Consulta%20Nexo%20Celer`}
                  class="btn-primary mt-6 w-fit"
                >
                  Enviar email
                </a>
              </div>
            )
          }
        </div>
      </div>
    </div>
  </div>
</section>
