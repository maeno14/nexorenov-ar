---
import { navLinks, site } from '../config/site';
---

<header class="sticky top-0 z-50 border-b border-nexo-border/80 bg-nexo-surface/90 backdrop-blur-md">
  <div class="container-nexo flex items-center justify-between gap-4 px-5 py-4 sm:px-8 lg:px-12">
    <a href="/" class="group flex items-center gap-2.5">
      <span
        class="flex h-9 w-9 items-center justify-center rounded-lg bg-nexo-ink text-sm font-bold text-white transition group-hover:bg-nexo-accent"
        aria-hidden="true"
      >
        NR
      </span>
      <span class="font-display text-lg font-semibold tracking-tight text-nexo-ink">
        {site.name}
      </span>
    </a>

    <nav class="hidden items-center gap-8 md:flex" aria-label="Principal">
      {
        navLinks.map((link) => (
          <a
            href={link.href}
            class="text-sm font-medium text-nexo-muted transition hover:text-nexo-accent"
          >
            {link.label}
          </a>
        ))
      }
    </nav>

    <a
      href="#contacto"
      class="rounded-full bg-nexo-ink px-4 py-2 text-sm font-semibold text-white transition hover:bg-nexo-accent"
    >
      Agendar consulta
    </a>
  </div>
</header>
