---
const services = [
  {
    title: 'Diagnóstico de procesos',
    description:
      'Mapeamos flujos administrativos, cuellos de botella y riesgos operativos para priorizar con datos.',
    tag: 'tag-blue',
    featured: true,
  },
  {
    title: 'Automatización',
    description:
      'Workflows digitales, aprobaciones y notificaciones trazables para sacar carga repetitiva de los equipos.',
    tag: 'tag-green',
    featured: false,
  },
  {
    title: 'Integración de sistemas',
    description:
      'Conectamos ERP, planillas, documentación y herramientas existentes sin romper lo que ya funciona.',
    tag: 'tag-yellow',
    featured: false,
  },
  {
    title: 'Adopción de IA',
    description:
      'Identificamos casos de uso concretos: clasificación documental, extracción de datos y asistencia operativa.',
    tag: 'tag-blue',
    featured: false,
  },
  {
    title: 'Change management',
    description:
      'Capacitación y acompañamiento para que las personas adopten el cambio sin frenar la operación.',
    tag: 'tag-green',
    featured: false,
  },
];
---

<section id="servicios" class="section-pad border-t border-border bg-canvas-alt">
  <div class="container-nexo">
    <div class="reveal max-w-2xl" style="--index: 0">
      <p class="eyebrow">Servicios</p>
      <h2 class="heading-display mt-3 text-3xl font-semibold sm:text-4xl">
        Consultoría para modernizar la gestión administrativa
      </h2>
      <p class="mt-4 text-lg text-muted">
        Diagnóstico, diseño, implementación y adopción — con foco en resultados medibles para
        equipos que necesitan orden, velocidad y trazabilidad.
      </p>
    </div>

    <div class="mt-14 grid gap-4 lg:grid-cols-3">
      {
        services.map((service, i) => (
          <article
            class:list={[
              'card card-hover reveal p-6 lg:p-8',
              service.featured && 'lg:col-span-2',
            ]}
            style={`--index: ${i + 1}`}
          >
            <div>
              <span class:list={['tag', service.tag]}>
                {String(i + 1).padStart(2, '0')}
              </span>
              <h3
                class:list={[
                  'mt-4 font-medium text-ink',
                  service.featured ? 'text-2xl' : 'text-xl',
                ]}
              >
                {service.title}
              </h3>
              <p class="mt-3 text-sm leading-relaxed text-muted">{service.description}</p>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>
