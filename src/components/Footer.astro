---
import { site, productExternalUrl } from '../config/site';
import LogoMark from './LogoMark.astro';

const year = new Date().getFullYear();
---

<footer class="border-t border-border bg-canvas">
  <div class="container-nexo px-5 py-12 sm:px-8 lg:px-12">
    <div class="flex flex-col gap-8 md:flex-row md:items-start md:justify-between">
      <div class="flex gap-4">
        <LogoMark size={40} variant="light" class="shrink-0" />
        <div>
          <p class="text-base font-medium text-ink">{site.name}</p>
          <p class="mt-2 max-w-sm text-sm text-muted">
            Consultoría de software B2B para empresas en modernización de procesos administrativos.
          </p>
          <p class="mt-4 text-sm text-muted">
            <a href={site.url} class="link-muted">nexoceler.ar</a>
            <span class="mx-1">·</span>
            Producto:{' '}
            <a
              href={productExternalUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="link-muted"
            >
              {site.product.name}
            </a>
          </p>
        </div>
      </div>

      <nav class="flex flex-col gap-2 text-sm" aria-label="Pie de página">
        <a href="#servicios" class="link-muted">Servicios</a>
        <a
          href={productExternalUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="link-muted"
        >
          {site.product.name}
        </a>
        <a href="#contacto" class="link-muted">Contacto</a>
        <a href={`mailto:${site.email}`} class="link-muted">{site.email}</a>
      </nav>
    </div>

    <div
      class="mt-10 flex flex-col gap-2 border-t border-border pt-6 text-xs text-muted sm:flex-row sm:items-center sm:justify-between"
    >
      <p>© {year} {site.name}. Todos los derechos reservados.</p>
      <p>Argentina</p>
    </div>
  </div>
</footer>
