---
import { site } from '../config/site';
---

<section class="section-pad">
  <div class="container-nexo">
    <div class="reveal max-w-4xl" style="--index: 0">
      <span class="tag tag-blue">Consultoría de software · B2B</span>
      <h1 class="heading-display mt-6 text-4xl font-semibold sm:text-5xl lg:text-[3.25rem]">
        Aceleramos procesos administrativos en la era de la modernización y la IA
      </h1>
      <p class="mt-6 max-w-2xl text-lg text-muted">
        {site.name} acompaña a empresas que necesitan ordenar operaciones, integrar
        sistemas y adoptar innovación con criterio — con diagnóstico, implementación y
        software a medida cuando hace falta.
      </p>
      <div class="mt-10 flex flex-wrap gap-3">
        <a href="#contacto" class="btn-primary"> Agendar consulta </a>
        <a href="#servicios" class="btn-secondary"> Ver servicios </a>
      </div>
    </div>

    <div class="reveal mt-16 grid gap-4 sm:grid-cols-2 lg:grid-cols-4" style="--index: 1">
      <div class="card card-hover p-6">
        <p class="eyebrow">Enfoque</p>
        <p class="mt-2 text-lg font-medium text-ink">Procesos admin.</p>
      </div>
      <div class="card card-hover p-6">
        <p class="eyebrow">Cliente</p>
        <p class="mt-2 text-lg font-medium text-ink">Empresas B2B</p>
      </div>
      <div class="card card-hover p-6">
        <p class="eyebrow">Momento</p>
        <p class="mt-2 text-lg font-medium text-ink">Modernización</p>
      </div>
      <div class="card card-hover p-6">
        <p class="eyebrow">Innovación</p>
        <p class="mt-2 text-lg font-medium text-ink">IA aplicada</p>
      </div>
    </div>
  </div>
</section>
