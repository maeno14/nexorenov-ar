---
import { site, productExternalUrl } from '../config/site';
---

<section class="section-pad">
  <div class="container-nexo">
    <div class="reveal max-w-4xl" style="--index: 0">
      <span class="tag tag-blue">Consultoría B2B</span>
      <h1 class="heading-display mt-6 text-4xl font-semibold sm:text-5xl lg:text-[3.25rem]">
        Software y procesos para equipos que operan en volumen
      </h1>
      <p class="mt-6 max-w-2xl text-lg text-muted">
        {site.name} acompaña a estudios contables y empresas que necesitan ordenar
        operaciones administrativas, integrar sistemas y adoptar herramientas como{' '}
        {site.product.name} sin sumar fricción al día a día.
      </p>
      <div class="mt-10 flex flex-wrap gap-3">
        <a href="#contacto" class="btn-primary"> Agendar consulta </a>
        <a
          href={productExternalUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="btn-secondary"
        >
          Conocer {site.product.name}
        </a>
      </div>
    </div>

    <div class="reveal mt-16 grid gap-4 sm:grid-cols-2 lg:grid-cols-4" style="--index: 1">
      <div class="card card-hover p-6">
        <p class="eyebrow">Enfoque</p>
        <p class="mt-2 text-lg font-medium text-ink">Procesos admin.</p>
      </div>
      <div class="card card-hover p-6">
        <p class="eyebrow">Sector</p>
        <p class="mt-2 text-lg font-medium text-ink">Contable / fiscal</p>
      </div>
      <div class="card card-hover p-6">
        <p class="eyebrow">Producto</p>
        <p class="mt-2 text-lg font-medium text-ink">{site.product.name}</p>
      </div>
      <div class="card card-hover p-6">
        <p class="eyebrow">Resultado</p>
        <p class="mt-2 text-lg font-medium text-ink">Lotes AFIP</p>
      </div>
    </div>
  </div>
</section>
