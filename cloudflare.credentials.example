# Copiá este archivo a cloudflare.credentials y completá los valores.
# Ese archivo está en .gitignore — nunca se sube a GitHub.
#
# NO uses el token de cloudflared (Cloudflare Tunnel).
# Para Pages necesitás un API Token de Cloudflare:
#
# 1. https://dash.cloudflare.com/profile/api-tokens
# 2. Create Token → "Edit Cloudflare Workers" (incluye Pages)
#    O plantilla "Cloudflare Pages" si aparece
# 3. Account Resources: tu cuenta
# 4. Zone Resources: All zones (o solo nexoceler.ar si ya lo tenés)
#
# Account ID: Dashboard → cualquier sitio → Overview → columna derecha "Account ID"

CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=

# Nombre del proyecto en Pages (por defecto igual al repo)
CLOUDFLARE_PAGES_PROJECT=nexoceler-ar
